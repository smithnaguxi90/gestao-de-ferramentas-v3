{
  "name": "gestao-de-ferramentas-v3",
  "version": "3.0.0",
  "description": "Sistema de Gestão de Ferramentas - COENG",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backup": "node backup-database.mjs",
    "export": "node export-firebase-data.mjs",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "electron:dev": "electron .",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.coeng.gestaoferramentas",
    "productName": "Gestão de Ferramentas - COENG",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "firebase": "^12.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.2.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "workbox-precaching": "^7.3.0"
  }
}
